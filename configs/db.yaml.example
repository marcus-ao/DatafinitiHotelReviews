# ============================================================
# PostgreSQL 数据库连接配置示例
# 复制为 db.yaml 并填入真实连接信息
# cp configs/db.yaml.example configs/db.yaml
# 注意: db.yaml 是脚本唯一使用的数据库配置源，且已在 .gitignore 中，不会提交
# ============================================================

postgres:
  host: "localhost"
  port: 5432
  dbname: "hotel_reviews_kb"
  user: "hotel_user"
  password: "your_password_here"
  schema: "kb"
