# Copy this file to `.env`.

LLM_JUDGE_MODEL=deepseek-chat
LLM_JUDGE_API_MODE=auto
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional advanced overrides:
# JUDGE_API_KEY=
# JUDGE_API_BASE_URL=
